generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserProfile {
  id                  Int      @id @default(autoincrement())
  chatId              String   @unique
  heightCm            Float?
  currentWeightKg     Float?
  goalType            String?
  dailyCaloriesKcal   Float?
  dailyProteinG       Float?
  dailyFatG           Float?
  dailyCarbsG         Float?
  dailyFiberG         Float?
  sex               String?
  birthDate         DateTime?
  activityLevel     Float?
  notificationsEnabled Boolean  @default(true)
  notificationCount    Int      @default(3)
  notificationTimes    String?
  desiredWeightKg      Float?
  city                 String?
  timezone             String?
  preferredName        String?
  referralCode         String?  @unique
  referredBy           String?
  referredByRole       String?
  trainerOfferType     String?
  referralLockedAt     DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model MealEntry {
  id            Int      @id @default(autoincrement())
  chatId        String
  text          String
  mealType      String   @default("unknown")
  sourceType    String   @default("text")
  photoFileId   String?
  voiceFileId   String?
  caloriesKcal  Float?
  proteinG      Float?
  fatG          Float?
  carbsG        Float?
  fiberG        Float?
  createdAt     DateTime @default(now())
}

model WeightEntry {
  id        Int      @id @default(autoincrement())
  chatId    String
  weightKg  Float
  createdAt DateTime @default(now())
}

model TrainerProfile {
  id                      Int       @id @default(autoincrement())
  chatId                  String    @unique
  verificationStatus      String    @default("pending")
  bio                     String?
  specialization          String?
  referralCode            String?   @unique
  fullName                String?
  socialLink              String?
  documentLink            String?
  appliedAt               DateTime?
  verifiedAt              DateTime?
  rejectedAt              DateTime?
  blockedAt               DateTime?
  verifiedByAdminId       String?
  verificationNote        String?
  connectionCode          String?
  connectionCodeExpiresAt DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

model TrainerClientLink {
  id                Int      @id @default(autoincrement())
  trainerId         String
  clientId          String
  status            String   @default("active")
  fullHistoryAccess Boolean  @default(false)
  canViewPhotos     Boolean  @default(true)
  connectedAt       DateTime @default(now())
  disconnectedAt    DateTime?
  @@unique([trainerId, clientId])
}

model TrainerRating {
  id         Int      @id @default(autoincrement())
  trainerId  String
  clientId   String
  targetType String
  targetId   String
  rating     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@unique([trainerId, clientId, targetType, targetId])
}

model Subscription {
  id                 Int      @id @default(autoincrement())
  chatId             String   @unique
  planId             String   @default("free")
  status             String   @default("trial")
  trialEndsAt        DateTime?
  currentPeriodEnd   DateTime?
  autoRenew          Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model MealReminder {
  id        Int      @id @default(autoincrement())
  chatId    String
  mealType  String
  time      String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TrainerReward {
  id             Int      @id @default(autoincrement())
  trainerId      String
  referredChatId String
  planId         String
  amountRub      Float    @default(0)
  status         String   @default("pending_hold")
  holdUntil      DateTime?
  paidAt         DateTime?
  createdAt      DateTime @default(now())
}
