generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Platform-independent user identity ──────────────────────────────────────

model User {
  id             String            @id @default(uuid())
  createdAt      DateTime          @default(now())
  mergedAt       DateTime?
  identities     UserIdentity[]
  profile        UserProfile?
  trainerProfile TrainerProfile?
  subscription   UserSubscription?
  payments       Payment[]
}

model UserIdentity {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  platform   String   // 'telegram' | 'max'
  platformId String   // chatId for telegram, userId for MAX
  username   String?
  firstName  String?
  linkedAt   DateTime @default(now())

  @@unique([platform, platformId])
  @@unique([userId, platform])
}

// ─── Subscription & payments (keyed by userId) ───────────────────────────────

model UserSubscription {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id])
  planId          String    // 'client_monthly' | 'trial'
  status          String    // 'active' | 'past_due' | 'canceled' | 'expired'
  currentPeriodEnd DateTime?
  trialEndsAt     DateTime?
  gracePeriodEnd  DateTime?
  autoRenew       Boolean   @default(true)
  providerSubId   String?   // external subscription ID from payment provider
  paymentProvider String?   // 'yookassa' | 'cloudpayments' — set when provider is connected
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  payments        Payment[]
}

model Payment {
  id                String            @id @default(uuid())
  userId            String
  user              User              @relation(fields: [userId], references: [id])
  subscriptionId    String?
  subscription      UserSubscription? @relation(fields: [subscriptionId], references: [id])
  provider          String            // 'yookassa' | 'cloudpayments' | 'manual'
  providerPaymentId String?           @unique
  planId            String
  amountRub         Float
  status            String            // 'pending' | 'succeeded' | 'failed' | 'canceled' | 'refunded'
  periodStart       DateTime?
  periodEnd         DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  attempts          PaymentAttempt[]
}

model PaymentAttempt {
  id               String   @id @default(uuid())
  paymentId        String
  payment          Payment  @relation(fields: [paymentId], references: [id])
  status           String   // 'pending' | 'succeeded' | 'failed'
  providerResponse String?  // raw JSON response from provider
  createdAt        DateTime @default(now())
}

model WebhookLog {
  id          String    @id @default(uuid())
  provider    String    // 'yookassa' | 'cloudpayments'
  eventType   String
  payloadJson String
  processedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())
}

// ─── Account linking (TG ↔ MAX multi-platform) ───────────────────────────────

/// One-time cross-platform link request.
/// Flow: initiator (new platform) creates request → gets a code → canonical user
/// (existing platform) confirms with the code → UserIdentity of the new platform
/// is reassigned to the canonical userId.
model AccountLinkRequest {
  id                  String    @id @default(uuid())
  /// userId of the account that wants to be linked (the "new" / second platform)
  initiatorUserId     String
  /// Platform of the initiating account ('telegram' | 'max')
  initiatorPlatform   String
  /// Platform-specific ID of the initiating account (chatId for Telegram)
  initiatorPlatformId String
  /// Short uppercase hex code shown to the initiator; entered in the canonical account
  code                String    @unique
  /// pending → confirmed | expired | canceled
  status              String    @default("pending")
  /// userId of the account that confirmed the link (the canonical / first account)
  canonicalUserId     String?
  createdAt           DateTime  @default(now())
  /// Code expires 15 minutes after creation
  expiresAt           DateTime
  confirmedAt         DateTime?

  @@index([initiatorUserId, status])
  @@index([status, expiresAt])
}

// ─── Existing models (still keyed by chatId during transition) ────────────────

model UserProfile {
  id                  Int      @id @default(autoincrement())
  chatId              String   @unique
  userId              String?  @unique  // platform-independent ID; null for legacy records not yet backfilled
  user                User?    @relation(fields: [userId], references: [id])
  heightCm            Float?
  currentWeightKg     Float?
  goalType            String?
  dailyCaloriesKcal   Float?
  dailyProteinG       Float?
  dailyFatG           Float?
  dailyCarbsG         Float?
  dailyFiberG         Float?
  sex               String?
  birthDate         DateTime?
  activityLevel     Float?
  notificationsEnabled Boolean  @default(true)
  notificationCount    Int      @default(3)
  notificationTimes    String?
  desiredWeightKg      Float?
  city                 String?
  timezone             String?
  preferredName        String?
  telegramUsername     String?  // Telegram @username, updated lazily on each bootstrap
  avatarData           String?  // base64 data URL for user avatar
  referralCode         String?  @unique
  referredBy           String?          // chatId (legacy)
  referredByUserId     String?          // platform-independent; null for legacy records not yet backfilled
  referredByRole       String?
  trainerOfferType     String?
  referralLockedAt     DateTime?
  expertReferralSourceCode String?   // erf_ code captured when future expert first visited bot
  goalStartWeightKg   Float?   // currentWeightKg at the moment the current desiredWeightKg was set
  goalStartedAt       DateTime? // when the current goal anchor was recorded
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model MealEntry {
  id            Int      @id @default(autoincrement())
  chatId        String   // legacy; kept for backward compatibility
  userId        String?  // platform-independent; null for records created by Telegram bot or not yet backfilled
  text          String
  mealType      String   @default("unknown")
  sourceType    String   @default("text")
  photoFileId   String?
  voiceFileId   String?
  photoData            String?  // base64 data URL — populated for legacy records; null for R2-backed records
  photoStorageKey      String?  // R2 object key, e.g. meal-photos/{chatId}/{ts}.jpg; null for legacy records
  photoStorageProvider String?  // 'r2' — set together with storageKey; null for legacy records
  photoSizeBytes       Int?     // original file size in bytes; null for legacy records
  caloriesKcal  Float?
  proteinG      Float?
  fatG          Float?
  carbsG        Float?
  fiberG        Float?
  createdAt     DateTime @default(now())
  @@index([userId])
  @@index([chatId])
}

model SavedMeal {
  id             Int      @id @default(autoincrement())
  chatId         String   // legacy; kept for backward compatibility
  userId         String?  // platform-independent; null for records without userId
  title          String
  totalWeightG   Float?   // total weight of the whole dish in grams; used to scale macros per portion
  caloriesKcal   Float?
  proteinG       Float?
  fatG           Float?
  carbsG         Float?
  fiberG         Float?
  mealType       String?  // optional default meal type for quick-add
  notes          String?  // reserved for ingredient assembly payload (JSON)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@index([userId])
  @@index([chatId])
}

model WeightEntry {
  id        Int      @id @default(autoincrement())
  chatId    String   // legacy; kept for backward compatibility
  userId    String?  // platform-independent; null for records not yet backfilled
  weightKg  Float
  createdAt DateTime @default(now())
  @@index([userId])
  @@index([chatId])
}

model TrainerProfile {
  id                      Int       @id @default(autoincrement())
  chatId                  String    @unique
  userId                  String?   @unique  // platform-independent ID; null for legacy records not yet backfilled
  user                    User?     @relation(fields: [userId], references: [id])
  verificationStatus      String    @default("pending")
  bio                     String?
  specialization          String?
  referralCode            String?   @unique
  fullName                String?
  socialLink              String?
  documentLink            String?
  appliedAt               DateTime?
  verifiedAt              DateTime?
  rejectedAt              DateTime?
  blockedAt               DateTime?
  verifiedByAdminId       String?
  verificationNote        String?
  connectionCode          String?
  connectionCodeExpiresAt DateTime?
  avatarData                       String?   // base64 data URL
  verificationPhotoData            String?   // base64 selfie — populated for legacy records; null for R2-backed records
  verificationPhotoStorageKey      String?   // R2 object key, e.g. trainer-verification-photos/{chatId}.jpg; null for legacy
  verificationPhotoStorageProvider String?   // 'r2' — set together with storageKey; null for legacy records
  verificationPhotoSizeBytes       Int?      // original file size in bytes; null for legacy records
  requisitesData                   String?   // JSON-encoded company requisites (ИП/ООО fields)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

model TrainerClientLink {
  id                Int      @id @default(autoincrement())
  trainerId         String   // chatId (legacy)
  clientId          String   // chatId (legacy)
  trainerUserId     String?  // platform-independent; null for legacy records not yet backfilled
  clientUserId      String?  // platform-independent; null for legacy records not yet backfilled
  status            String   @default("active")
  fullHistoryAccess Boolean  @default(false)
  canViewPhotos     Boolean  @default(true)
  clientAlias       String?  // trainer-private label for this client
  connectedAt       DateTime @default(now())
  disconnectedAt    DateTime?
  @@unique([trainerId, clientId])
  @@index([clientId])
}

model TrainerRating {
  id            Int      @id @default(autoincrement())
  trainerId     String   // chatId (legacy)
  clientId      String   // chatId (legacy)
  trainerUserId String?  // platform-independent; null for legacy records not yet backfilled
  clientUserId  String?  // platform-independent; null for legacy records not yet backfilled
  targetType    String
  targetId      String
  rating        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@unique([trainerId, clientId, targetType, targetId])
}

model Subscription {
  id                 Int      @id @default(autoincrement())
  chatId             String   @unique
  planId             String   @default("free")
  status             String   @default("trial")
  trialEndsAt        DateTime?
  currentPeriodEnd   DateTime?
  autoRenew          Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model MealReminder {
  id        Int      @id @default(autoincrement())
  chatId    String
  mealType  String
  time      String
  dayOfWeek String?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TrainerReview {
  id                  Int      @id @default(autoincrement())
  clientId            String
  trainerId           String
  rating              Int
  reviewText          String?
  allowTrainerComment Boolean  @default(true)
  trainerComment      String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  @@unique([clientId, trainerId])
}

model TrainerReward {
  id               Int      @id @default(autoincrement())
  trainerId        String   // chatId (legacy)
  referredChatId   String   // chatId (legacy)
  trainerUserId    String?  // platform-independent; null for legacy records not yet backfilled
  referredUserId   String?  // platform-independent; null for legacy records not yet backfilled
  planId           String
  amountRub        Float    @default(0)
  status           String   @default("pending_hold") // pending_hold | available | requested | paid_out | cancelled
  payoutRequestId  Int?     // set when status='requested', links to PayoutRequest
  holdUntil        DateTime?
  paidAt           DateTime?
  createdAt        DateTime @default(now())
}

// ─── Payout requests (trainer / company initiated) ────────────────────────────

model PayoutRequest {
  id                  Int      @id @default(autoincrement())
  trainerId           String   // chatId — matches TrainerProfile.chatId
  trainerUserId       String?  // platform-independent userId; null for legacy records
  amountRub           Float
  requisitesSnapshot  String   // JSON snapshot of requisites at request time
  rewardIds           String   // JSON array of TrainerReward.id values covered by this request
  status              String   @default("pending") // pending | approved | paid | cancelled
  note                String?  // admin note

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([trainerId])
  @@index([trainerUserId])
  @@index([status])
}

model TrainerDocument {
  id              Int      @id @default(autoincrement())
  chatId          String   // trainer's chatId (legacy key, consistent with rest of project)
  docType         String   // 'diploma' | 'certificate' | 'other'
  title           String?  // optional user-provided label
  fileData        String?  // base64 data URL — populated for legacy records; null for R2-backed records
  mimeType        String   // 'image/jpeg' | 'image/png' | 'image/webp' | 'application/pdf'
  storageKey      String?  // R2 object key, e.g. trainer-documents/{chatId}/{id}.pdf; null for legacy base64 records
  storageProvider String?  // 'r2' — set together with storageKey; null for legacy records
  sizeBytes       Int?     // original file size in bytes; null for legacy records
  createdAt       DateTime @default(now())

  @@index([chatId])
}

model NutritionInsightCache {
  id            Int      @id @default(autoincrement())
  chatId        String
  period        String   // 'day' | 'week'
  periodKey     String   // YYYY-MM-DD for day; week-start YYYY-MM-DD for week
  mealSignature String   // "${count}_${latestCreatedAt}" — changes when data changes
  contentJson   String   // JSON.stringify(InsightResult)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@unique([chatId, period, periodKey])
}

// ─── Expert acquisition referral (separate from client referral system) ─────

model ExpertAcquisition {
  id                    Int       @id @default(autoincrement())

  // Invited expert (the one who was recruited)
  invitedExpertChatId   String    @unique  // chatId of the new expert
  invitedExpertUserId   String?            // userId if available

  // Referrer (expert or company who recruited)
  referrerChatId        String             // chatId of the referrer
  referrerUserId        String?            // userId if available
  referrerType          String             // 'expert' | 'company'
  referralCode          String             // TrainerProfile.referralCode used

  // Phase 1 qualification window
  phase1StartsAt        DateTime           // same as attributedAt
  phase1EndsAt          DateTime           // phase1StartsAt + 30 days
  phase1ClientCount     Int       @default(0)  // clients connected during phase 1

  // Qualification (> 5 clients in phase 1 → 100% on new phase-2 clients)
  isQualified           Boolean   @default(false)
  qualifiedAt           DateTime?

  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([referrerChatId])
  @@index([referrerUserId])
}

// ─── User behaviour events ───────────────────────────────────────────────────

model UserEvent {
  id        Int      @id @default(autoincrement())
  userId    String   // platform-independent userId (required — events without userId are dropped)
  platform  String   @default("unknown") // 'telegram' | 'max' | 'unknown'
  eventName String   // see ALLOWED_EVENTS whitelist in events route
  metadata  Json?    // optional safe context, no secrets/base64
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([eventName, createdAt])
  @@index([createdAt])
  @@index([platform, createdAt])
}

// ─── AI cost telemetry (internal, not user-facing) ───────────────────────────

model AiCostLog {
  id          Int      @id @default(autoincrement())
  userId      String?  // platform-independent userId; null for legacy users without userId
  chatId      String?  // legacy fallback; may be null for users with userId only
  scenario    String   // 'food_text' | 'food_photo' | 'food_ingredients' | 'nutrition_insight_daily' | 'nutrition_insight_weekly' | 'requisites_ocr'
  model       String   // e.g. 'gpt-4o-mini', 'gpt-4o'
  inputTokens Int
  outputTokens Int
  totalTokens Int
  costUsd     Float
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([chatId])
  @@index([scenario])
  @@index([createdAt])
}
